#!/bin/bash
set -euo pipefail

# ─── Defaults ────────────────────────────────────────────────────────────────
ACCOUNT=""
TIME="1:00:00"
CONSTRAINT="cpu"
GPUS=""
WORKSPACE="$(pwd)"
IMAGE_AGENT="docker.io/nollde24/claude-nersc:latest"
IMAGE_PROXY="docker.io/nollde24/claude-nersc-proxy:latest"

# ─── Usage ───────────────────────────────────────────────────────────────────
usage() {
    cat << 'EOF'
claude-nersc — Launch Claude Code in a sandboxed container on NERSC Perlmutter

Usage:
  claude-nersc -A <account> [options]

Options:
  -A, --account ACCOUNT   NERSC account/project (required)
  -t, --time TIME         Time limit (default: 1:00:00)
  -C, --constraint TYPE   Node type: cpu or gpu (default: cpu)
  -g, --gpus N            Number of GPUs (implies --constraint gpu)
  -w, --workspace DIR     Workspace directory to mount (default: current dir)
      --agent-image IMG   Override agent image
      --proxy-image IMG   Override proxy image
  -h, --help              Show this help

Examples:
  claude-nersc -A m3246
  claude-nersc -A m3246 -t 2:00:00 -C gpu -g 1
  claude-nersc -A m3246 -w ~/my-project
EOF
    exit 0
}

# ─── Parse arguments ─────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
    case $1 in
        -A|--account)     ACCOUNT="$2";      shift 2 ;;
        -t|--time)        TIME="$2";         shift 2 ;;
        -C|--constraint)  CONSTRAINT="$2";   shift 2 ;;
        -g|--gpus)        GPUS="$2"; CONSTRAINT="gpu"; shift 2 ;;
        -w|--workspace)   WORKSPACE="$2";    shift 2 ;;
        --agent-image)    IMAGE_AGENT="$2";  shift 2 ;;
        --proxy-image)    IMAGE_PROXY="$2";  shift 2 ;;
        -h|--help)        usage ;;
        *)                echo "Unknown option: $1"; echo; usage ;;
    esac
done

if [ -z "$ACCOUNT" ]; then
    echo "ERROR: --account / -A is required"
    echo
    usage
fi

WORKSPACE="$(cd "$WORKSPACE" && pwd)"

# ─── Pin Podman version ─────────────────────────────────────────────────────
# Workaround: the Dec 2024 Podman update on Perlmutter breaks --userns=keep-id
# (especially with --gpu). Pin to the older Podman until NERSC resolves this.
# docs: https://docs.nersc.gov/development/containers/podman-hpc/overview/#known-issues
PODMAN_OLD=/global/common/shared/das/podman-4.7.0/bin/podman
if [ -x "$PODMAN_OLD" ]; then
    export PODMANHPC_PODMAN_BIN="$PODMAN_OLD"
    echo "Using pinned Podman: $PODMAN_OLD"
else
    echo "WARNING: Pinned Podman not found at $PODMAN_OLD, using system default"
fi

# ─── If not in a Slurm allocation, pre-pull images and request one ──────────
if [ -z "${SLURM_JOB_ID:-}" ]; then
    # Pre-pull images on the login node (shared filesystem makes them
    # available on compute nodes). 
    # (Pulling from compute nodes can lead to errors)
    echo "Pre-pulling images on login node..."
    podman-hpc pull "$IMAGE_PROXY"
    podman-hpc pull "$IMAGE_AGENT"
    echo "Images ready."

    SALLOC_ARGS=(
        --nodes 1
        --qos interactive
        --time "$TIME"
        --constraint "$CONSTRAINT"
        --account "$ACCOUNT"
    )
    if [ -n "$GPUS" ]; then
        SALLOC_ARGS+=(--gpus "$GPUS")
    fi

    echo "Requesting compute node: ${SALLOC_ARGS[*]}"
    exec salloc "${SALLOC_ARGS[@]}" \
        "$0" -A "$ACCOUNT" -t "$TIME" -C "$CONSTRAINT" \
        ${GPUS:+-g "$GPUS"} \
        -w "$WORKSPACE" \
        --agent-image "$IMAGE_AGENT" \
        --proxy-image "$IMAGE_PROXY"
fi

# ─── We have an allocation — start containers ───────────────────────────────
PROXY_NAME="claude-nersc-proxy-$$"
COMPUTE_NODE=$(scontrol show hostnames "$SLURM_NODELIST" | head -n1)
echo "Compute node: $COMPUTE_NODE"

PROXY_PID=""
cleanup() {
    echo "Cleaning up..."
    [ -n "$PROXY_PID" ] && kill "$PROXY_PID" 2>/dev/null || true
    wait "$PROXY_PID" 2>/dev/null || true
}
trap cleanup EXIT

echo "Starting Squid proxy on $COMPUTE_NODE..."
srun --overlap --ntasks=1 --gpus=0 --export=ALL \
    podman-hpc run --rm --name "$PROXY_NAME" \
    --network=host \
    "$IMAGE_PROXY" \
    squid -N -f /etc/squid/squid.conf > /dev/null 2>&1 &
PROXY_PID=$!

# Wait for Squid to be ready (up to 15s)
echo "Waiting for Squid proxy..."
for i in $(seq 1 30); do
    if srun --overlap --ntasks=1 --gpus=0 --export=ALL podman-hpc ps --format '{{.Names}}' 2>/dev/null | grep -q "$PROXY_NAME"; then
        echo "Squid proxy ready."
        break
    fi
    if [ "$i" -eq 30 ]; then
        echo "ERROR: Squid proxy failed to start within 15s"
        exit 1
    fi
    sleep 0.5
done
echo "Launching Claude agent (workspace: $WORKSPACE)..."
echo "───────────────────────────────────────────────────"

srun --overlap --ntasks=1 ${GPUS:+--gpus=$GPUS --gpu-bind=none} --export=ALL --pty \
    podman-hpc run -it --rm \
    --network=host \
    ${GPUS:+--gpu} \
    --userns=keep-id:uid=1000,gid=1000 \
    -e SQUID_PROXY=127.0.0.1:3128 \
    -v "$WORKSPACE":/workspace \
    "$IMAGE_AGENT" \
    || true

echo "Session ended."
